# NEMOB OS — lokal konfiguration.
# Kopiera till nemob-os/.env och fyll i. .env är gitignorerad och får ALDRIG committas.

# Fullständig URL till Nordic-adminens read-only briefing-endpoint (inkl. hemlig slug).
# Värdet hårdkodas aldrig, loggas aldrig och visas aldrig i UI eller API-svar.
NORDIC_BRIEF_URL=

# Port för den lokala servern (valfri, standard 4571).
# NEMOB_OS_PORT=4571
