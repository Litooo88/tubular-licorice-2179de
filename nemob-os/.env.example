# NEMOB OS — lokal konfiguration.
# Kopiera till nemob-os/.env och fyll i. .env är gitignorerad och får ALDRIG committas.

# Fullständig URL till Nordic-adminens read-only briefing-endpoint (inkl. hemlig slug).
# Värdet hårdkodas aldrig, loggas aldrig och visas aldrig i UI eller API-svar.
NORDIC_BRIEF_URL=

# Port för den lokala servern (valfri, standard 4571).
# NEMOB_OS_PORT=4571

# Mobilläge: bind mot nätverket så telefonen når dashboarden (samma wifi).
# Kräver PIN (minst 6 tecken) — utan PIN vägrar servern starta utanför 127.0.0.1.
# NEMOB_OS_HOST=0.0.0.0
# NEMOB_OS_PIN=

# Slå upp ärende: read-only-sökning i verkstadens ärendedatabas.
# Samma token som Nordic-admin (x-admin-token). Endast GET görs — proxyn
# kan inte skriva. Tokenvärdet loggas aldrig och når aldrig telefonen.
# NORDIC_ADMIN_TOKEN=
# NORDIC_SITE_URL=https://www.nordicemobility.se
